---
import Layout from '../layouts/Layout.astro';


const values = [
  {
    title: "Quality Assurance",
    description: "Every product in our warehouse undergoes a strict quality check to ensure it meets the standards your customers expect.",
    icon: "🛡️"
  },
  {
    title: "Competitive Pricing",
    description: "By maintaining strong relationships with manufacturers, we pass on significant bulk savings to our retail partners.",
    icon: "💰"
  },
  {
    title: "Reliable Logistics",
    description: "Located in Mildenhall, our distribution center is positioned for rapid dispatch and dependable delivery across the UK.",
    icon: "🚛"
  }
];
---

<Layout title="About Us | Heath Court Ltd - UK Household Wholesale">
  

  <main class="bg-white">
    <!-- 1. HEADER SECTION -->
    <section class="bg-slate-50 py-16 border-b border-slate-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight">About Heath Court Ltd</h1>
        <p class="mt-4 text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
          Your trusted partner in wholesale household goods distribution, serving retailers and businesses since [Insert Year].
        </p>
      </div>
    </section>

    <!-- 2. MISSION & STORY SECTION -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row items-center gap-16">
          <div class="lg:w-1/2">
            <h2 class="text-3xl font-bold text-slate-900 mb-6 uppercase tracking-wide">Our Story</h2>
            <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">Bridging the gap between quality manufacturing and retail success.</h3>
            <div class="space-y-4 text-lg text-slate-600 leading-relaxed">
              <p>
                Based in the heart of Suffolk, Heath Court Ltd started with a simple goal: to provide high-quality household goods at prices that allow businesses to grow. We understand the challenges of modern retail, and we aim to be the most reliable link in your supply chain.
              </p>
              <p>
                From our warehouse at 82 James Carter Road, we manage a diverse inventory ranging from essential kitchenware to decorative home accents. Our focus has always been on consistency—consistent quality, consistent pricing, and consistent delivery.
              </p>
            </div>
          </div>
          <div class="lg:w-1/2 grid grid-cols-2 gap-4">
            <img src="https://images.unsplash.com/photo-1590602847861-f357a9332bbc?auto=format&fit=crop&q=80&w=400" alt="Household Items" class="rounded-xl shadow-md mt-8" />
            <img src="https://images.unsplash.com/photo-1550989460-0adf9ea622e2?auto=format&fit=crop&q=80&w=400" alt="Wholesale Warehouse" class="rounded-xl shadow-md" />
          </div>
        </div>
      </div>
    </section>

    <!-- 3. CORE VALUES SECTION -->
    <section class="py-24 bg-slate-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold">Why Partner With Us?</h2>
          <div class="w-24 h-1 bg-blue-500 mx-auto mt-4"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {values.map(value => (
            <div class="bg-slate-800 p-8 rounded-2xl border border-slate-700 hover:border-blue-500 transition-colors">
              <div class="text-4xl mb-6">{value.icon}</div>
              <h3 class="text-xl font-bold mb-4">{value.title}</h3>
              <p class="text-slate-400 leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. LOCATION & LOGISTICS SECTION -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-blue-50 rounded-3xl p-8 md:p-16 flex flex-col lg:flex-row items-center justify-between">
          <div class="lg:w-1/2 mb-10 lg:mb-0">
            <h2 class="text-3xl font-bold text-slate-900 mb-6 tracking-tight">Strategic UK Distribution</h2>
            <p class="text-lg text-slate-700 mb-8 leading-relaxed">
              Our headquarters at **Unit A 82 James Carter Road, Mildenhall**, is perfectly situated to serve the UK's logistics network. This central location allows us to maintain a large stock inventory and process orders with industry-leading speed.
            </p>
            <div class="space-y-4">
              <div class="flex items-center text-slate-900 font-semibold">
                <span class="w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center mr-4 text-sm">1</span>
                Rapid processing of bulk orders
              </div>
              <div class="flex items-center text-slate-900 font-semibold">
                <span class="w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center mr-4 text-sm">2</span>
                Direct access to major UK freight routes
              </div>
              <div class="flex items-center text-slate-900 font-semibold">
                <span class="w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center mr-4 text-sm">3</span>
                On-site quality control inspections
              </div>
            </div>
          </div>
          <div class="lg:w-1/3 text-center">
            <div class="bg-white p-8 rounded-2xl shadow-xl">
              <p class="text-slate-500 uppercase tracking-widest text-xs font-bold mb-2">Visit Our Warehouse</p>
              <h4 class="text-xl font-bold text-slate-900 mb-4">Bury St. Edmunds, England</h4>
              <p class="text-slate-600 text-sm mb-6">Unit A 82 James Carter Road, Mildenhall, IP28 7DE</p>
              <a 
                href="/contact" 
                class="inline-block w-full py-3 bg-slate-900 text-white font-bold rounded-lg hover:bg-slate-800 transition-colors"
              >
                Schedule a Visit
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. FINAL CALL TO ACTION -->
    <section class="py-20 text-center">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">Want to see our full product range?</h2>
      <a href="/products" class="text-blue-600 font-bold text-lg hover:underline underline-offset-8">
        View the Wholesale Catalog &rarr;
      </a>
    </section>
  </main>


</Layout>