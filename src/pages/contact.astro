---
import Layout from '../layouts/Layout.astro';


const contactInfo = {
  address: "Unit A 82 James Carter Road, Mildenhall, Bury St. Edmunds, IP28 7DE",
  email: "sales@heathcourt.co.uk",
  phone: "+44 (0) 1638 XXX XXX", // Replace with actual number
  hours: "Mon - Fri: 09:00 - 17:30",
};
---

<Layout title="Contact Us | Heath Court Ltd Wholesale">


  <main class="bg-slate-50">
    <!-- 1. HEADER -->
    <section class="bg-white border-b border-slate-200 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Get in Touch</h1>
        <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">
          Inquire about bulk pricing, open a trade account, or schedule a warehouse visit. Our team is here to support your business.
        </p>
      </div>
    </section>

    <!-- 2. CONTACT GRID -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          
          <!-- Column 1 & 2: Contact Form -->
          <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 p-8 md:p-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-8">Wholesale Inquiry Form</h2>
            
            <form action="#" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="full-name" class="block text-sm font-semibold text-slate-700 mb-2">Full Name</label>
                <input type="text" id="full-name" name="full-name" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="John Doe" required />
              </div>
              <div>
                <label for="company-name" class="block text-sm font-semibold text-slate-700 mb-2">Company Name</label>
                <input type="text" id="company-name" name="company-name" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="Retailers Ltd" required />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">Business Email</label>
                <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="john@company.com" required />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="+44 0000 000000" />
              </div>
              <div class="md:col-span-2">
                <label for="subject" class="block text-sm font-semibold text-slate-700 mb-2">Nature of Inquiry</label>
                <select id="subject" name="subject" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all">
                  <option>Request Price List / Catalog</option>
                  <option>Open a New Trade Account</option>
                  <option>Order Status Inquiry</option>
                  <option>Warehouse Visit Appointment</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="md:col-span-2">
                <label for="message" class="block text-sm font-semibold text-slate-700 mb-2">Your Message</label>
                <textarea id="message" name="message" rows="5" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="Please provide details about the products you are interested in..." required></textarea>
              </div>
              <div class="md:col-span-2">
                <button type="submit" class="w-full bg-blue-600 text-white font-bold py-4 rounded-lg hover:bg-blue-700 transition-colors shadow-lg shadow-blue-200">
                  Send Inquiry
                </button>
              </div>
            </form>
          </div>

          <!-- Column 3: Contact Details -->
          <div class="space-y-8">
            <div class="bg-slate-900 text-white rounded-2xl p-8 shadow-xl">
              <h3 class="text-xl font-bold mb-6">Contact Details</h3>
              <div class="space-y-6">
                <div class="flex items-start">
                  <div class="bg-blue-600 p-2 rounded-lg mr-4">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  </div>
                  <p class="text-slate-300 text-sm leading-relaxed">
                    {contactInfo.address}
                  </p>
                </div>
                <div class="flex items-center">
                  <div class="bg-blue-600 p-2 rounded-lg mr-4">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                  </div>
                  <a href={`mailto:${contactInfo.email}`} class="text-slate-300 text-sm hover:text-white transition-colors">{contactInfo.email}</a>
                </div>
                <div class="flex items-center">
                  <div class="bg-blue-600 p-2 rounded-lg mr-4">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                  </div>
                  <span class="text-slate-300 text-sm">{contactInfo.phone}</span>
                </div>
              </div>

              <div class="mt-10 pt-10 border-t border-slate-800">
                <h4 class="font-bold text-white mb-4">Warehouse Hours</h4>
                <p class="text-slate-400 text-sm">{contactInfo.hours}</p>
                <p class="text-slate-500 text-xs mt-2">Weekends: Closed (Appointments only)</p>
              </div>
            </div>

            <!-- Trade Badge -->
            <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6">
              <h4 class="text-blue-900 font-bold mb-2 uppercase text-xs tracking-widest">B2B Trade Only</h4>
              <p class="text-blue-700 text-sm">We are a wholesale-only distributor. Please include your company registration number in the message for faster account approval.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. GOOGLE MAPS SECTION -->
    <section class="h-112.5 w-full bg-slate-200">
      <!-- To use a real map: Replace the iframe src with a Google Maps Embed link for Unit A 82 James Carter Road -->
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2440.0631628109314!2d0.4851253770425717!3d52.3421299491799!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47d86f9160533e4b%3A0xc6b62145396594d2!2sJames%20Carter%20Rd%2C%20Mildenhall%2C%20Bury%20Saint%20Edmunds%20IP28%207DE!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk" 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </section>
  </main>


</Layout>