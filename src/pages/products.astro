---
import Layout from '../layouts/Layout.astro';


// Mock Product Data (In a real app, this would come from a CMS or Content Collections)
const products = [
  { id: 'HC-001', name: 'Stainless Steel Cookware Set', category: 'Kitchenware', moq: '10 Units', carton: '2 Sets', image: 'https://images.unsplash.com/photo-1584990344321-27682ad0f994?auto=format&fit=crop&q=80&w=400' },
  { id: 'HC-002', name: 'Microfibre Cleaning Cloths (50pk)', category: 'Cleaning', moq: '20 Packs', carton: '10 Packs', image: 'https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=400' },
  { id: 'HC-003', name: 'Ceramic Dinner Plate - White', category: 'Kitchenware', moq: '48 Units', carton: '12 Units', image: 'https://images.unsplash.com/photo-1574199960812-3bb320659db3?auto=format&fit=crop&q=80&w=400' },
  { id: 'HC-004', name: 'Glass Storage Jars (Set of 3)', category: 'Storage', moq: '15 Units', carton: '5 Sets', image: 'https://images.unsplash.com/photo-1530514120320-c28854460067?auto=format&fit=crop&q=80&w=400' },
  { id: 'HC-005', name: 'Industrial Floor Mop Head', category: 'Cleaning', moq: '30 Units', carton: '10 Units', image: 'https://images.unsplash.com/photo-1585833014768-fb66117db5e5?auto=format&fit=crop&q=80&w=400' },
  { id: 'HC-006', name: 'Velvet Clothes Hangers (20pk)', category: 'Storage', moq: '25 Packs', carton: '5 Packs', image: 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?auto=format&fit=crop&q=80&w=400' },
];

const categories = ['All', 'Kitchenware', 'Cleaning', 'Storage', 'Decor'];
---

<Layout title="Product Catalog | Heath Court Ltd Wholesale">
  

  <main class="bg-white min-h-screen">
    <!-- 1. PAGE HEADER -->
    <header class="bg-slate-900 py-16 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-4">Wholesale Catalog</h1>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          High-quality household essentials available for bulk order. 
          Register for a trade account to view full pricing.
        </p>
      </div>
    </header>

    <!-- 2. FILTER & TOOLS BAR -->
    <section class="sticky top-20 z-40 bg-white border-b border-slate-200 shadow-sm py-4 px-4">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <!-- Category Pills -->
        <div class="flex gap-2 overflow-x-auto pb-2 md:pb-0 no-scrollbar w-full md:w-auto">
          {categories.map(cat => (
            <button class="whitespace-nowrap px-6 py-2 rounded-full border border-slate-200 text-sm font-medium hover:bg-blue-600 hover:text-white transition-colors">
              {cat}
            </button>
          ))}
        </div>
        
        <!-- Search Bar -->
        <div class="relative w-full md:w-80">
          <input type="text" placeholder="Search SKU or Product..." class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
          <svg class="w-5 h-5 absolute left-3 top-2.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
      </div>
    </section>

    <!-- 3. PRODUCT GRID -->
    <section class="py-12 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          {products.map(product => (
            <div class="group bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-2xl transition-all duration-300 flex flex-col">
              <!-- Image Container -->
              <div class="relative aspect-square bg-slate-100 overflow-hidden">
                <img src={product.image} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <span class="absolute top-3 left-3 bg-white/90 backdrop-blur px-2 py-1 rounded text-[10px] font-bold text-slate-700 uppercase tracking-widest shadow-sm border border-slate-100">
                  SKU: {product.id}
                </span>
              </div>

              <!-- Product Info -->
              <div class="p-5 grow">
                <p class="text-blue-600 text-xs font-bold uppercase tracking-widest mb-1">{product.category}</p>
                <h3 class="text-slate-900 font-bold text-lg mb-4 line-clamp-1">{product.name}</h3>
                
                <!-- B2B Details Table -->
                <div class="grid grid-cols-2 gap-4 py-4 border-y border-slate-50 mb-6">
                  <div>
                    <p class="text-slate-400 text-[10px] uppercase font-bold tracking-tighter">Min. Order (MOQ)</p>
                    <p class="text-slate-800 font-semibold text-sm">{product.moq}</p>
                  </div>
                  <div>
                    <p class="text-slate-400 text-[10px] uppercase font-bold tracking-tighter">Carton Size</p>
                    <p class="text-slate-800 font-semibold text-sm">{product.carton}</p>
                  </div>
                </div>

                <a 
                  href="/contact" 
                  class="block w-full text-center bg-slate-900 text-white py-3 rounded-lg font-bold text-sm hover:bg-blue-600 transition-colors shadow-sm"
                >
                  Inquire for Pricing
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. NO-STOCK NOTICE / CTA -->
    <section class="py-16 bg-blue-50">
      <div class="max-w-3xl mx-auto text-center px-4">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Don't see what you're looking for?</h2>
        <p class="text-slate-600 mb-8">
          We have hundreds of additional products arriving weekly at our Mildenhall warehouse. 
          Contact our sourcing team with your specific requirements.
        </p>
        <a href="/contact" class="inline-flex items-center text-blue-600 font-bold hover:gap-2 transition-all">
          Contact Sourcing Team 
          <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </section>
  </main>

  
</Layout>

<style>
  /* Utility to hide scrollbar but allow scrolling */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>